{
  "name": "server",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "description": "Effect Platform API for the edu_effect-rag-builder experiment.",
  "keywords": [
    "rag",
    "ai",
    "effect",
    "bun",
    "rpc",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/edu_effect-rag-builder.git"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=bun --minify --sourcemap --external:msgpackr-extract",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "bun --watch run src/index.ts",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.41",
    "@repo/ai": "workspace:*",
    "@repo/rag": "workspace:*",
    "@repo/domain": "workspace:*",
    "@repo/observability": "workspace:*",
    "effect": "4.0.0-beta.41"
  },
  "devDependencies": {
    "@effect/language-service": "^0.81.0",
    "@effect/vitest": "4.0.0-beta.41",
    "@repo/config-typescript": "workspace:*",
    "@types/bun": "1.3.11",
    "vitest": "^4.1.0"
  }
}
