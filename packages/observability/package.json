{
  "name": "@repo/observability",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OpenTelemetry wiring for edu_effect-rag-builder.",
  "keywords": [
    "observability",
    "opentelemetry",
    "tracing",
    "effect"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/edu_effect-rag-builder.git"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "type-check": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo dist node_modules tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@effect/opentelemetry": "4.0.0-beta.36",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/sdk-trace-web": "^2.6.0",
    "effect": "4.0.0-beta.36"
  },
  "devDependencies": {
    "@repo/config-typescript": "workspace:*"
  }
}
